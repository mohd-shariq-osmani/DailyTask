<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Built-in Intent to update task status via Voice -->
    <capability android:name="actions.intent.UPDATE_TODO_ITEM">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.dailytask.app"
            android:targetClass="com.dailytask.app.MainActivity">
            <!-- Map Assistant parameter (task title) to intent extra 'taskName' -->
            <parameter
                android:name="todoItem.name"
                android:key="taskName" />
            <!-- Map Assistant parameter (completed status) to intent extra 'taskStatus' -->
            <parameter
                android:name="todoItem.status"
                android:key="taskStatus" />
        </intent>
    </capability>
</shortcuts>
